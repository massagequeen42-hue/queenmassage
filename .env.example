# ===========================================
# QueenMassage Environment Variables
# ===========================================

# App
NEXT_PUBLIC_APP_URL=https://queenmassage.id
NEXT_PUBLIC_APP_NAME=QueenMassage

# Database - Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/queenmassage?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/queenmassage?sslmode=require"

# NextAuth
NEXTAUTH_URL=https://queenmassage.id
NEXTAUTH_SECRET=your-secret-key-here

# Google OAuth (for admin login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890
NEXT_PUBLIC_WHATSAPP_MESSAGE=Halo QueenMassage, saya ingin booking massage.

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=your-clarity-id

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your-blob-token

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Admin Email (for NextAuth)
ADMIN_EMAIL=admin@queenmassage.id
